# AI Stock Advisor - Frontend Environment Variables
#
# 사용법:
#   1) 이 파일을 `.env.local`로 복사 (gitignored)
#   2) 값 채우고 `pnpm dev` 실행
#
# 주의: NEXT_PUBLIC_* 접두어가 붙은 변수만 브라우저에 노출됨.
#       서버 전용 시크릿(Supabase service key, Gemini key 등)은 절대 이 파일에 추가하지 말 것.
#       서버 전용 값은 apps/api 의 .env 참조.

# ===== Backend API =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# ===== Site =====
# sitemap.ts / robots.ts / OG 메타 태그에서 사용
NEXT_PUBLIC_SITE_URL=http://localhost:3000
