# AI Stock Advisor - Backend Environment Variables
#
# 사용법:
#   1) 이 파일을 `.env`로 복사 (`.env`는 .gitignored)
#   2) IDE run config 또는 쉘에서 `export $(grep -v '^#' .env | xargs)` 후 `./gradlew bootRun`
#   3) 또는 IntelliJ "Run Configuration → Environment Variables" 에 로딩
#
# 로컬 YAML 오버라이드 대안: `application-local.yml.example` → `application-local.yml` 복사 후 편집
#
# 주의: 서버 전용 시크릿. 절대 FE (.env.local) 에 복사하지 말 것.

# ===== Database (Supabase PostgreSQL) =====
# Supabase 프로젝트 Settings > Database 에서 Connection String 복사
DATABASE_URL=jdbc:postgresql://localhost:5432/aistockadvisor
DATABASE_USERNAME=dev
DATABASE_PASSWORD=dev

# ===== Cache (Upstash Redis) =====
# https://console.upstash.com → Database → REST URL/Token 또는 Redis URL
REDIS_URL=redis://localhost:6379

# ===== External Data Providers =====
# https://finnhub.io (무료 60 req/min)
FINNHUB_API_KEY=
# https://www.alphavantage.co (fallback, 5 req/min)
ALPHAVANTAGE_API_KEY=

# ===== AI =====
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ===== Auth (Phase 4 예비) =====
# Supabase Dashboard > Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=

# ===== Runtime =====
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_LOG_LEVEL=DEBUG
