root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Java / Gradle (BE)
[*.{java,kt,kts,gradle}]
indent_size = 4

# Python (있을 경우)
[*.py]
indent_size = 4

# YAML
[*.{yml,yaml}]
indent_size = 2

# Markdown: 줄 끝 공백이 의미 있는 경우 (line break) 보존
[*.md]
trim_trailing_whitespace = false

# Makefile: tab 필수
[Makefile]
indent_style = tab
