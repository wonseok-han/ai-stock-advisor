# AI Stock Advisor - Backend Environment Variables
#
# 사용법 (권장):
#   1) 이 파일을 .env.local 로 복사 (.gitignored)
#        cp apps/api/.env.example apps/api/.env.local
#   2) 값 채움 후 `make api-dev` 실행
#      → Makefile 이 apps/api/.env.local 을 자동 source 해서 JVM 에 환경변수 주입.
#         Spring Boot 는 dotenv 를 직접 지원하지 않으므로 Make 레벨에서 처리함.
#   3) IDE 로 기동할 때는 Run Configuration → Environment Variables 에 수동 등록 필요.
#
# YAML 오버라이드 대안: application.example.yml → application-local.yml 복사 후 편집.
#   env 하나로 충분한 경우 대부분 불필요.
#
# 주의: 서버 전용 시크릿. 절대 FE (.env.local) 에 복사하지 말 것.

# ===== Database (Supabase PostgreSQL) =====
# Supabase 프로젝트 Settings > Database 에서 Connection String 복사
DATABASE_URL=jdbc:postgresql://localhost:5432/aistockadvisor
DATABASE_USERNAME=dev
DATABASE_PASSWORD=dev

# ===== Cache (Upstash Redis) =====
# https://console.upstash.com → Database → REST URL/Token 또는 Redis URL
REDIS_URL=redis://localhost:6379

# ===== External Data Providers =====
# https://finnhub.io (무료 60 req/min) — search / profile / quote / news 담당.
# 주의: /stock/candle 은 무료 플랜 403. 캔들은 아래 Twelve Data 사용.
FINNHUB_API_KEY=

# https://twelvedata.com (무료 800 req/day, 8 req/min) — OHLCV 캔들 담당.
TWELVE_DATA_API_KEY=

# https://financialmodelingprep.com (무료 250 req/day) — market movers (gainers/losers) 담당.
FMP_API_KEY=

# https://www.alphavantage.co (legacy fallback, 5 req/min). 현재 미사용.
ALPHAVANTAGE_API_KEY=

# ===== AI =====
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ===== Auth (Phase 4 예비) =====
# Supabase Dashboard > Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=

# ===== Runtime =====
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_LOG_LEVEL=DEBUG
