spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/aistockadvisor
    username: dev
    password: dev
  data:
    redis:
      url: redis://localhost:6379

app:
  external:
    finnhub:
      api-key: YOUR_FINNHUB_API_KEY
    alphavantage:
      api-key: YOUR_ALPHAVANTAGE_API_KEY
    gemini:
      api-key: YOUR_GEMINI_API_KEY
  supabase:
    jwt-secret: YOUR_SUPABASE_JWT_SECRET

logging:
  level:
    com.aistockadvisor: DEBUG
